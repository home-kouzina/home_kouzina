<odoo>
    <!-- Report Action -->
    <record id="action_hk_inventory_pdf" model="ir.actions.report">
        <field name="name">HK Inventory PDF</field>
        <field name="model">hk.inventory.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hk_inventory_report.hk_inventory_pdf</field>
        <field name="print_report_name">'HK Inventory Report - %s' % (object.id)</field>
    </record>

    <!-- Wizard Form View -->
    <record id="view_hk_inventory_wizard_form" model="ir.ui.view">
        <field name="name">hk.inventory.report.wizard.form</field>
        <field name="model">hk.inventory.report.wizard</field>
        <field name="arch" type="xml">
            <form string="HK Inventory Report">
                <group>
                    <button name="action_generate_excel" string="Generate Excel" type="object" class="btn-primary"/>
                    <button name="action_generate_pdf" string="Generate PDF" type="object" class="btn-secondary"/>
                </group>
            </form>
        </field>
    </record>

    <!-- ✅ Window Action (This was missing) -->
    <record id="action_hk_inventory_wizard" model="ir.actions.act_window">
        <field name="name">HK Inventory Report</field>
        <field name="res_model">hk.inventory.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_hk_inventory_wizard_form"/>
    </record>

    <!-- ✅ Menu Item linked to action -->
    <menuitem id="menu_hk_inventory_reporting_root"
              name="HK Inventory Report"
              parent="stock.menu_warehouse_report"
              action="action_hk_inventory_wizard"/>
</odoo>
