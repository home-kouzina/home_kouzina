<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_weekly_inventory_upload" model="ir.sequence">
        <field name="name">Weekly Inventory Upload</field>
        <field name="code">weekly.inventory.upload</field>
        <field name="prefix">WIU/</field>
        <field name="padding">4</field>
    </record>

    <record id="view_weekly_inventory_upload_tree" model="ir.ui.view">
        <field name="name">weekly.inventory.upload.tree</field>
        <field name="model">weekly.inventory.upload</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="upload_filename"/>
                <field name="upload_date"/>
                <field name="uploaded_by"/>
                <field name="total_rows"/>
                <field name="success_rows"/>
                <field name="failed_rows"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_weekly_inventory_upload_form" model="ir.ui.view">
        <field name="name">weekly.inventory.upload.form</field>
        <field name="model">weekly.inventory.upload</field>
        <field name="arch" type="xml">
            <form string="Weekly Inventory Upload">
                <header>
                    <button name="action_download_sample_template" string="Download Sample Template" type="object" class="btn-secondary"/>
                    <button name="action_process_upload" string="Process Inventory" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_download_error_report" string="Download Error Report" type="object" class="btn-secondary" invisible="not error_file"/>
                    <button name="action_undo_upload" string="Undo Last Upload" type="object" class="btn-danger" invisible="not can_undo" confirm="This will restore previous quantities for all successful rows in this upload. Continue?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,processed,undone"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="upload_file" filename="upload_filename"/>
                            <field name="upload_filename" invisible="1"/>
                            <field name="upload_date" readonly="1"/>
                            <field name="uploaded_by" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_rows" readonly="1"/>
                            <field name="success_rows" readonly="1"/>
                            <field name="failed_rows" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="message_summary" readonly="1" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Upload Logs">
                            <field name="line_ids" readonly="1">
                                <list>
                                    <field name="row_number"/>
                                    <field name="product_name"/>
                                    <field name="warehouse_name"/>
                                    <field name="old_qty"/>
                                    <field name="new_qty"/>
                                    <field name="status"/>
                                    <field name="message"/>
                                    <field name="undo_done"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_weekly_inventory_upload" model="ir.actions.act_window">
        <field name="name">Weekly Inventory Upload</field>
        <field name="res_model">weekly.inventory.upload</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Create a new upload, download the sample template, upload the Excel file, and process inventory by location.</p>
        </field>
    </record>

    <menuitem id="menu_weekly_inventory_upload_root"
              name="Weekly Inventory Upload"
              parent="stock.menu_stock_inventory_control"
              action="action_weekly_inventory_upload"
              sequence="90"/>
</odoo>
