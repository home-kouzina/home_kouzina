<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="amazon_account_payment_backfill_view_form" model="ir.ui.view">
        <field name="name">amazon.account.payment.backfill.form</field>
        <field name="model">amazon.account</field>
        <field name="inherit_id" ref="sale_amazon.amazon_account_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_backfill_payment_methods" type="object" 
                        string="Backfill Payment Methods" class="oe_highlight"
                        help="Fetch payment methods from Amazon for all previous orders that don't have them"/>
            </xpath>
        </field>
    </record>

</odoo>
