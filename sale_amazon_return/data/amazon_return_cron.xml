<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_sync_amazon_returns" model="ir.cron">
        <field name="name">Amazon: sync FBM and FBA returns</field>
        <field name="model_id" ref="sale_amazon.model_amazon_account"/>
        <field name="state">code</field>
        <field name="code">model._sync_returns()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="nextcall" eval="(DateTime.now() + timedelta(minutes=15)).strftime('%Y-%m-%d %H:%M:%S')"/>
        <field name="priority">1000</field>
    </record>
</odoo>
