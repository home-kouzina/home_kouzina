<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_uom_change_wizard_form" model="ir.ui.view">
        <field name="name">product.uom.change.wizard.form</field>
        <field name="model">product.uom.change.wizard</field>
        <field name="arch" type="xml">
            <form string="Change Product UoM">
                <group>
                    <field name="selected_product_count"/>
                    <field name="product_tmpl_ids" widget="many2many_tags" options="{'no_create': True}"/>
                    <field name="current_uom_id"/>
                    <field name="new_uom_id" options="{'no_create': True}"/>
                    <field name="change_purchase_uom"/>
                </group>
                <footer>
                    <button string="Apply" type="object" name="action_apply_uom" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="product_uom_change_wizard_action" model="ir.actions.act_window">
        <field name="name">Change Product UoM</field>
        <field name="res_model">product.uom.change.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="product_template_change_uom_server_action" model="ir.actions.server">
        <field name="name">Change UoM</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list,form</field>
        <field name="groups_id" eval="[(4, ref('uom.group_uom'))]"/>
        <field name="state">code</field>
        <field name="code">
first_product = records[:1]
action = {
    "type": "ir.actions.act_window",
    "name": "Change Product UoM",
    "res_model": "product.uom.change.wizard",
    "view_mode": "form",
    "target": "new",
    "context": dict(
        env.context,
        default_product_tmpl_ids=[(6, 0, records.ids)],
        default_new_uom_id=first_product.uom_id.id if first_product else False,
    ),
}
        </field>
    </record>
</odoo>
