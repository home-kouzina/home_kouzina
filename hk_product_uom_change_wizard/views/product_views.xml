<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_change_uom_wizard" model="ir.ui.view">
        <field name="name">product.template.form.change.uom.wizard</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_uom_change_wizard"
                        type="object"
                        string="Change UoM"
                        class="btn-secondary"
                        groups="uom.group_uom"/>
            </xpath>
        </field>
    </record>

    <record id="product_product_form_change_uom_wizard" model="ir.ui.view">
        <field name="name">product.product.form.change.uom.wizard</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_uom_change_wizard"
                        type="object"
                        string="Change UoM"
                        class="btn-secondary"
                        groups="uom.group_uom"/>
            </xpath>
        </field>
    </record>
</odoo>
