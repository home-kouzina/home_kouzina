<odoo>
    <record id="view_stock_picking_form_inherit_logistic" model="ir.ui.view">
        <field name="name">stock.picking.form.logistic.allocation</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <!-- Add logistic fields below scheduled date -->
            <xpath expr="//field[@name='origin']" position="after">
                <field name="logistic_id" readonly="state in ['done']"/>
                <field name="logistic_amount" readonly="state in ['done']"/>
            </xpath>
        </field>
    </record>
</odoo>
