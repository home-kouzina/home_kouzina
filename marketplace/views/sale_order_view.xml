<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_form_inherit_marketplace" model="ir.ui.view">
        <field name="name">sale.order.form.marketplace.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="marketplace_type"/>
<!--                <field name="partner_shipping_id"/>-->
                <field name="partner_shipping_id"
                    widget="res_partner_many2one"
                    domain="[('id', 'child_of', partner_id), ('type', 'in', ['delivery', 'contact', False])]"
                    context="{'show_address': 1, 'default_type': 'delivery'}"
                    options="{'no_create': True, 'no_create_edit': True}"/>
                <field name="partner_invoice_id"
                    widget="res_partner_many2one"
                    domain="[('id', 'child_of', partner_id), ('type', 'in', ['invoice','contact', False])]"
                    context="{'show_address': 1, 'default_type': 'invoice'}"
                    options="{'no_create': True, 'no_create_edit': True}"/>
            </xpath>

            <xpath expr="//page[@name='customer_signature']" position="after">
                <page string="Marketplace Info" name="marketplace_info">
                    <group>
                        <group name="marketplace_order_details" invisible="marketplace_type == False">
                            <field name="marketplace_order_ref"/>
                            <field name="marketplace_order_date"/>
                            <field name="marketplace_payment_status"/>
                            <field name="marketplace_order_status"/>
                            <field name="marketplace_delivery_slot"/>
                            <field name="marketplace_total_amount"/>
                        </group>
                        <group name="marketplace_invoice_details" invisible="marketplace_type == False">
                            <field name="marketplace_invoice_number"/>
                            <field name="marketplace_invoice_type"/>
                            <field name="marketplace_sale_state"/>
<!--                            <field name="marketplace_supply_city"/>-->
<!--                            <field name="marketplace_supply_country"/>-->
<!--                            <field name="marketplace_supply_state"/>-->
<!--                            <field name="marketplace_supply_state_gst"/>-->
                            <field name="marketplace_hsn_code"/>
                            <field name="marketplace_item_id"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
    <record id="view_order_list_inherit_marketplace" model="ir.ui.view">
        <field name="name">sale.order.list.marketplace.inherit</field>
        <field name="model">sale.order</field>
        <!-- Inherit the tree/list view -->
        <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding"/>
        <field name="arch" type="xml">
            <!-- Add marketplace fields after the customer field -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="marketplace_invoice_number"/>
                <field name="marketplace_invoice_type"/>
                <field name="marketplace_sale_state"/>
            </xpath>
        </field>
    </record>
</odoo>
