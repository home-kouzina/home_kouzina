<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_form_inherit_marketplace" model="ir.ui.view">
        <field name="name">sale.order.form.marketplace.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="marketplace_type"/>
            </xpath>

            <xpath expr="//page[@name='customer_signature']" position="after">
                <page string="Marketplace Info" name="marketplace_info">
                    <group>
                        <group name="flipkart_details" invisible="marketplace_type != 'flipkart'">
                            <field name="flipkart_order_id"/>
                            <field name="flipkart_order_date"/>
                            <field name="flipkart_payment_status"/>
                            <field name="flipkart_order_status"/>
                            <field name="flipkart_total_amount"/>
                        </group>

                        <group name="amazon_details" invisible="marketplace_type != 'amazon'">
                            <field name="amazon_order_id"/>
                            <field name="amazon_order_date"/>
                            <field name="amazon_payment_status"/>
                            <field name="amazon_order_status"/>
                            <field name="amazon_total_amount"/>
                        </group>

                        <group name="blinkit_details" invisible="marketplace_type != 'blinkit'">
                            <field name="blinkit_order_id"/>
                            <field name="blinkit_delivery_slot"/>
                            <field name="blinkit_payment_status"/>
                            <field name="blinkit_order_status"/>
                            <field name="blinkit_total_amount"/>
                        </group>

                        <group name="shopify_details" invisible="marketplace_type != 'shopify'">
                            <field name="shopify_order_id"/>
                            <field name="shopify_order_date"/>
                            <field name="shopify_payment_status"/>
                            <field name="shopify_order_status"/>
                            <field name="shopify_total_amount"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>