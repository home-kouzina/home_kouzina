<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_margin_report_search" model="ir.ui.view">
        <field name="name">sale.margin.report.search</field>
        <field name="model">sale.margin.report</field>
        <field name="arch" type="xml">
            <search string="Margin Report">
                <field name="so_name" string="Sales Order"/>
                <field name="customer_name" string="Customer"/>
                <field name="product_name" string="Product"/>
                <field name="sku" string="SKU"/>
                <field name="invoice_number" string="Invoice Number"/>
                <separator/>
                <filter name="filter_today" string="Today"
                    domain="[('order_date', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="filter_this_month" string="This Month"
                    domain="[('order_date', '&gt;=', (context_today().replace(day=1)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_customer" string="Customer" context="{'group_by': 'customer_name'}"/>
                    <filter name="group_product" string="Product" context="{'group_by': 'product_name'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_sale_margin_report_list" model="ir.ui.view">
        <field name="name">sale.margin.report.list</field>
        <field name="model">sale.margin.report</field>
        <field name="arch" type="xml">
            <list string="Sales Margin Report" create="false" edit="false" delete="false">
                <field name="so_name" string="Sales Order Number"/>
                <field name="customer_name" string="Customer Name"/>
                <field name="invoice_number" string="Invoice Number"/>
                <field name="product_name" string="Product Name"/>
                <field name="ean_number" string="EAN Number"/>
                <field name="sku" string="SKU"/>
                <field name="product_uom_qty" string="Qty"/>
                <field name="cogs" string="COGS" widget="monetary"/>
                <field name="nett" string="Nett(Untaxed)" widget="monetary"/>
                <field name="mrp" string="MRP" widget="monetary"/>
                <field name="cogs_percent" string="COGS %"/>
                <field name="gross_margin" string="Gross Margin %"/>
                <field name="total_amount_taxed" string="Total Amount (Taxed)" widget="monetary"/>
            </list>
        </field>
    </record>

    <record id="action_sale_margin_report" model="ir.actions.act_window">
        <field name="name">Margin Report</field>
        <field name="res_model">sale.margin.report</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_sale_margin_report_list"/>
        <field name="search_view_id" ref="view_sale_margin_report_search"/>
        <field name="context">{}</field>
    </record>
</odoo>