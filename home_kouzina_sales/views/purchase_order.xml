<odoo>
    <!-- Inherit Purchase Order Form -->
    <record id="view_purchase_order_form_inherit_regional_name" model="ir.ui.view">
        <field name="name">purchase.order.form.regional.name</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <!-- Add after quantity field inside order_line tree -->
            <xpath expr="//field[@name='order_line']/list/field[@name='product_id']" position="after">
                <field name="regional_language_name" string="Regional Name" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
