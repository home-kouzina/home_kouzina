<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Product Template Form -->
    <record id="view_product_template_form_inherit_barcode_label" model="ir.ui.view">
        <field name="name">product.template.form.barcode.label</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <field name="barcode" position="attributes">
                <attribute name="string">Barcode/EAN</attribute>
            </field>
            <xpath expr="//field[@name='lot_valuated']" position="after">
                <field name="is_finished_good"/>
                <field name="is_retail"/>
                <field name="is_consumable"/>
                <!-- <field name="cog_before_sale"/> -->
                <field name="regional_language_name"/>
            </xpath>


            
            
            <xpath expr="//header/button" position="before">
                  <button name="action_create_reorder_point"
                    type="object"
                    string="Create Reorder Point"
                    invisible="type not in ['consu']"
                    class="btn-primary"/>
            </xpath>
            <xpath expr="//field[@name='default_code']" position="attributes">
                <attribute name="string">SKU</attribute>
            </xpath>
            <xpath expr="//field[@name='barcode']" position="attributes">
                <attribute name="string">EAN</attribute>
            </xpath>
        </field>
    </record>

     <record id="view_product_template_tree_inherit_regional_name" model="ir.ui.view">
        <field name="name">product.template.tree.regional.name</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="regional_language_name"/>
            </xpath>
            <xpath expr="//field[@name='default_code']" position="attributes">
                <attribute name="string">SKU</attribute>
            </xpath>
            <xpath expr="//field[@name='barcode']" position="attributes">
                <attribute name="string">EAN</attribute>
            </xpath>
        </field>
    </record>

    <!-- Inherit Product Product Form -->
    <record id="view_product_product_form_inherit_barcode_label" model="ir.ui.view">
        <field name="name">product.product.form.barcode.label</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <field name="barcode" position="attributes">
                <attribute name="string">Barcode/EAN</attribute>
            </field>
            <xpath expr="//field[@name='lot_valuated']" position="after">
                <field name="is_finished_good"/>
                <field name="is_retail"/>
                <field name="cog_before_sale"/>
                <field name="regional_language_name"/>
            </xpath>
        </field>
    </record>

    <record id="view_product_product_tree_inherit_regional_name" model="ir.ui.view">
        <field name="name">product.product.tree.regional.name</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="regional_language_name"/>
            </xpath>
        </field>
    </record>

    <record id="view_product_template_form_labelling_packaging" model="ir.ui.view">
        <field name="name">product.template.form.labelling.packaging</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook/page[@name='general_information']" position="inside">
                <group string="Labelling and Packaging Information" colspan="4">
                    <field name="is_labelling"/>
                    <field name="is_packaging"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Inherit product.product form to show labelled_product many2many -->
    <record id="view_product_product_form_labelling_packaging" model="ir.ui.view">
        <field name="name">product.product.form.labelling.packaging</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook/page[@name='general_information']" position="inside">
                <group string="Labelled Products" colspan="4">
                    <!-- ✅ domain filters only is_labelling=True products -->
                    <!-- ✅ many2many_tags allows selecting multiple products -->
                    <field name="labelled_product"
                           widget="many2one_tags"
                           domain="[('is_labelling', '=', True)]"
                           options="{'no_create': True, 'no_create_edit': True}"/>
                    <field name="packaging_product"
                           widget="many2one_tags"
                           domain="[('is_packaging', '=', True)]"
                           options="{'no_create': True, 'no_create_edit': True}"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
