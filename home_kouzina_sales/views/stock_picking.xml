<odoo>
    <record id="view_picking_form_inherit_package_button" model="ir.ui.view">
        <field name="name">stock.picking.form.package.button</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <header>
                <button name="update_package_quantities"
                        type="object"
                        invisible="state in ['done']"
                        string="Update Package Quantities"
                        class="oe_highlight"/>
            </header>
        </field>
    </record>
</odoo>