<odoo>
    <record id="marketplace_master_view_form" model="ir.ui.view">
        <field name="name">marketplace.master.view.form</field>
        <field name="model">marketplace.master</field>
        <field name="arch" type="xml">
            <form string="Marketplace Master">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="warehouse_map"/>
                        <field name="so_tag"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="marketplace_master_view_list" model="ir.ui.view">
        <field name="name">marketplace.master.view.list</field>
        <field name="model">marketplace.master</field>
        <field name="arch" type="xml">
            <list string="Marketplace Master">
                <field name="name"/>
                <field name="code"/>
                <field name="warehouse_map"/>
                <field name="so_tag"/>
            </list>
        </field>
    </record>

    <record id="marketplace_master_action" model="ir.actions.act_window">
        <field name="name">Marketplace Master</field>
        <field name="res_model">marketplace.master</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_marketplace_csv_master" name="Marketplace Master" parent="sale.menu_sale_config"
              action="marketplace_master_action"/>

</odoo>
