<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_marketplace" model="ir.ui.view">
        <field name="name">account.move.form.marketplace</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">

            <!-- Add a New Tab -->
            <xpath expr="//notebook" position="inside">
                <page string="Marketplace Info">
                    <group>
                        <field name="marketplace_invoice_number"/>
                        <field name="marketplace_invoice_type"/>
                        <field name="marketplace_sale_state"/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>
</odoo>
