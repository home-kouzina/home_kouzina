<odoo>
    <record id="view_order_form_inherit_package" model="ir.ui.view">
        <field name="name">sale.order.form.package.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Adding the package field inside order lines tree -->
            <xpath expr="//field[@name='order_line']/list/field[@name='product_uom_qty']" position="after">
                <field name="package_ids" widget="many2many_tags"/>
                <field name="regional_language_name"/>
            </xpath>
        </field>
    </record>
</odoo>
