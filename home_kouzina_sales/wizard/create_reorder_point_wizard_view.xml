<odoo>
    <record id="view_create_reorder_point_wizard_form" model="ir.ui.view">
        <field name="name">reorder.point.wizard.form</field>
        <field name="model">reorder.point.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Reorder Point" version="7.0">
                <group>
                    <field name="product_id"/>
                    <field name="warehouse_id"/>
                    <field name="product_min_qty"/>
                    <field name="product_max_qty"/>
                </group>
                <footer>
                    <button string="Create" type="object" name="action_confirm_create" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
