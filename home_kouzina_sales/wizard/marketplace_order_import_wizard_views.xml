<odoo>
    <record id="marketplace_order_import_wizard_view_form" model="ir.ui.view">
        <field name="name">marketplace.order.import.wizard.view.form</field>
        <field name="model">marketplace.order.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Marketplace Orders">
                <sheet>
                    <group>
                        <field name="marketplace_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}"/>
                        <field name="xlsx_file" filename="xlsx_filename"/>
                        <field name="xlsx_filename" invisible="1"/>
                        <field name="confirm_orders"/>
                        <field name="create_customer_if_missing"/>
                        <field name="report_file" filename="report_filename" readonly="1" widget="download"
                               force_save="1" invisible="not report_filename"/>
                        <field name="report_filename" readonly="1" force_save="1" invisible="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_import_orders" string="Import" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_marketplace_order_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Marketplace Orders</field>
        <field name="res_model">marketplace.order.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
