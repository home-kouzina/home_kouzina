<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_inventory_variation_form_upload_inherit" model="ir.ui.view">
        <field name="name">inventory.variation.form.upload.inherit</field>
        <field name="model">inventory.variation</field>
        <field name="inherit_id" ref="hk_inventory_variation.view_inventory_variation_form"/>
        <field name="arch" type="xml">

            <!-- 1. Download Template: only after warehouse selected AND lines loaded
                 Process Upload: only when file is attached
                 Error Report: only when error file exists -->
            <button name="action_confirm" position="after">
                <button name="action_download_sample_template"
                        string="Download Template"
                        type="object"
                        class="btn-secondary"
                        invisible="state not in ['draft'] or not warehouse_ids or not line_ids"/>
                <button name="action_process_inventory_upload"
                        string="Process Inventory Upload"
                        type="object"
                        class="btn-primary"
                        invisible="state not in ['draft'] or not upload_file"/>
                <button name="action_download_error_report"
                        string="Download Error Report"
                        type="object"
                        class="btn-secondary"
                        invisible="not error_file"/>
            </button>

            <!-- 2. Add Upload Excel File field AFTER the existing two-column group
                    (date + warehouse_ids). Target the outer <group> that wraps both. -->
            <xpath expr="//sheet//group[group[field[@name='date']]]" position="after">
                <group invisible="not line_ids">
                    <group>
                        <field name="upload_file"
                               filename="upload_filename"
                               string="Upload Excel File"
                               readonly="state not in ['draft']"/>
                        <field name="upload_filename" invisible="1"/>
                    </group>
                    <group invisible="not total_rows">
                        <field name="upload_date" readonly="1"/>
                        <field name="uploaded_by" readonly="1"/>
                        <field name="total_rows" readonly="1"/>
                        <field name="success_rows" readonly="1"/>
                        <field name="failed_rows" readonly="1"/>
                    </group>
                </group>
                <group invisible="not message_summary">
                    <field name="message_summary" readonly="1" nolabel="1"/>
                </group>
            </xpath>

            <!-- 3. Add Upload Logs tab inside the notebook -->
            <notebook position="inside">
                <page string="Upload Logs" invisible="not upload_line_ids">
                    <field name="upload_line_ids" readonly="1">
                        <list decoration-danger="status == 'failed'"
                              decoration-success="status == 'success'">
                            <field name="row_number" optional="hide"/>
                            <field name="product_name" string="Product"/>
                            <field name="location_name" string="Location"/>
                            <field name="old_qty" string="Old Physical Qty"/>
                            <field name="new_qty" string="New Physical Qty"/>
                            <field name="status"/>
                            <field name="message" optional="show"/>
                        </list>
                    </field>
                </page>
            </notebook>

        </field>
    </record>

</odoo>
