<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="inventory_variation_action" model="ir.actions.act_window">
        <field name="name">Inventory Variations</field>
        <field name="res_model">inventory.variation</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_inventory_variation_root"
              name="Inventory Variation"
              parent="stock.menu_warehouse_report"
    />

    <menuitem id="menu_inventory_variation_sessions"
              name="Variation Sessions"
              parent="menu_inventory_variation_root"
              action="inventory_variation_action"/>

    <record id="view_inventory_variation_list" model="ir.ui.view">
        <field name="name">inventory.variation.list</field>
        <field name="model">inventory.variation</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="warehouse_id"/>
                <field name="state"
                       decoration-info="state=='draft'"
                       decoration-success="state=='reported'"
                       decoration-primary="state=='confirmed'"
                />
                <field name="total_variation"/>
                <button name="action_create_excel_report"
                        type="object"
                        icon="fa-file-excel-o"
                        help="Export selected variations as Excel file"/>
                <button name="action_download_pdf_report"
                        type="object"
                        icon="fa-file-pdf-o"
                        help="Generate and download PDF report"/>
            </list>
        </field>
    </record>

    <record id="view_inventory_variation_form" model="ir.ui.view">
        <field name="name">inventory.variation.form</field>
        <field name="model">inventory.variation</field>
        <field name="arch" type="xml">
            <form string="Inventory Variation">
                <header>
                    <button name="action_load_products" type="object" string="Load Products" class="btn-primary"
                            invisible="state not in ['draft']"/>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-success"
                            invisible="state not in ['draft']"
                            groups="hk_inventory_variation.group_inventory_variation_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,reported"/>
                </header>

                <sheet>
                    <widget name="web_ribbon" text="Draft"
                            invisible="state not in ['draft']" bg_color="bg-info"/>
                    <widget name="web_ribbon" text="Confirmed"
                            invisible="state not in ['confirmed']" bg_color="bg-primary"/>
                    <widget name="web_ribbon" text="Reported"
                            invisible="state not in ['reported']" bg_color="bg-success"/>
                    <div style="font-size:35px; font-weight:bold; margin-bottom:20px; color: purple;">
                        <field name="name" readonly="1" nolabel="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="date" readonly="state not in ['draft']"/>
                        </group>
                        <group>
                            <field name="warehouse_id"
                                   readonly="state not in ['draft']"
                                   options="{'no_create': True, 'no_edit': True, 'no_open': True}"
                            />
                        </group>
                    </group>

                    <!-- Notebook for variation lines -->
                    <notebook>
                        <page string="Variation Lines">
                            <field name="line_ids" readonly="state not in ['draft']">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="location_id"/>
                                    <field name="uom_id"/>
                                    <field name="physical_qty"/>
                                    <field name="theoretical_qty"/>
                                    <field name="variation_qty"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                    <!-- Buttons at bottom right -->
                    <div style="text-align: right; margin-top: 50px;">
                        <span style="display:inline-block; margin-right:10px;">
                            <button name="action_create_excel_report" type="object" string="Export as Excel"
                                    class="btn-success"
                                    invisible="state not in ['confirmed','reported']"/>
                        </span>
                        <span style="display:inline-block;">
                            <button name="action_download_pdf_report" type="object" string="Download PDF"
                                    class="btn-info"
                                    invisible="state not in ['confirmed','reported']"/>
                        </span>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
