<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="stock_picking_form_view_auto_receipt_lots" model="ir.ui.view">
        <field name="name">stock.picking.form.auto.receipt.lots</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <field name="show_auto_assign_receipt_lots" invisible="1"/>
                <button name="action_auto_assign_receipt_lots"
                        type="object"
                        string="Assign Lots"
                        class="btn-secondary"
                        invisible="not show_auto_assign_receipt_lots"/>
            </xpath>
        </field>
    </record>
</odoo>