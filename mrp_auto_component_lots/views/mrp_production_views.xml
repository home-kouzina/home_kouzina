<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_production_form_view" model="ir.ui.view">
        <field name="name">mrp.production.form</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <field name="show_auto_assign_finished_lot" invisible="1"/>
                <field name="is_manufacture_approver" invisible="1"/>
                <field name="approval_status"
                       widget="statusbar"
                       statusbar_visible="draft,pending,approved"/>
                <button name="action_auto_assign_finished_lot"
                        type="object"
                        string="Assign Finished Lot"
                        class="btn-secondary"
                        invisible="not show_auto_assign_finished_lot"/>


                <button name="action_approved_submit"
                        type="object"
                        string="Submit for Approval"
                        class="btn-primary"
                        invisible="state != 'draft' or approval_status not in (False, 'draft')"
                        />


                <button name="action_approved"
                        type="object"
                        string="Approve"
                        class="btn-primary"
                        invisible="not is_manufacture_approver or approval_status != 'pending'"
                        />             
                    
            </xpath>
        </field>
    </record>
</odoo>
