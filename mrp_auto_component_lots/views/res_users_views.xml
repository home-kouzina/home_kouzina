<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_users_manufacture_approver_view" model="ir.ui.view">
        <field name="name">res.users.manufacture.approver</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.user_groups_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[contains(@class, 'o_label_nowrap')]/group[position() = last() - 2]/field[last()]" position="after">
                <field name="manufacture_approver"/>
            </xpath>
        </field>
    </record>
</odoo>
