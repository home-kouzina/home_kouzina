<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_auto_component_lot_prefix" model="ir.ui.view">
        <field name="name">product.template.form.auto.component.lot.prefix</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="active" eval="False"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='inventory']" position="inside">
                <group string="Automatic Component Lot" groups="stock.group_production_lot">
                    <field name="auto_component_lot_prefix" placeholder="Auto, e.g. AM"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
