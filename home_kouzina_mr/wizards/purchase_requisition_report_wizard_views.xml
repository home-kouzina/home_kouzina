<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="purchase_requisition_excel_report_wizard_form_view" model="ir.ui.view">
            <field name="name">purchase.requisition.excel.report.wizard.form</field>
            <field name="model">purchase.requisition.excel.report.wizard</field>
            <field name="arch" type="xml">
                <form string="Purchase Requisition Excel Report">
                    <group>
                        <group>
                            <field name="start_date"/>
                            <field name="request_raised_by"/>
                        </group>
                        <group>
                            <field name="end_date"/>
                            <field name="request_raised_for"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_generate_excel_report" string="Download" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>