<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_invoice_document_inherit_mfg_expiry"
          inherit_id="account.report_invoice_document">

        <xpath expr="//table[@name='invoice_line_table']" position="before">
            <t t-set="show_mfg_date"
            t-value="any(line.manufacturing_date for line in o.invoice_line_ids)"/>
            <t t-set="show_expiry_date"
            t-value="any(line.expiry_date for line in o.invoice_line_ids)"/>
        </xpath>

        <xpath expr="//table[@name='invoice_line_table']//thead//th[@name='th_quantity']"
            position="before">
            <th name="th_manufacturing_date"
                class="text-start"
                t-if="show_mfg_date">
                <span>Mfg Date</span>
            </th>

            <th name="th_expiry_date"
                class="text-start"
                t-if="show_expiry_date">
                <span>Expiry Date</span>
            </th>
        </xpath>

        <xpath expr="//table[@name='invoice_line_table']//tbody//td[@name='td_quantity']"
            position="before">
            <td name="td_manufacturing_date"
                class="text-start"
                t-if="show_mfg_date">
                <span t-if="line.manufacturing_date"
                    t-field="line.manufacturing_date"/>
            </td>

            <td name="td_expiry_date"
                class="text-start"
                t-if="show_expiry_date">
                <span t-if="line.expiry_date"
                    t-field="line.expiry_date"/>
            </td>
        </xpath>

    </template>

</odoo>