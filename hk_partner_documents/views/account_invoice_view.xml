<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_mfg_expiry_dates" model="ir.ui.view">
        <field name="name">account.move.form.inherit.mfg.expiry.dates</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='price_unit']" position="after">
                <field name="manufacturing_date" optional="hide"/>
                <field name="expiry_date" optional="hide"/>
            </xpath>

        </field>
    </record>
</odoo>