        <xpath expr="//t[@t-set='address']/div[@t-field='o.partner_id']" position="before">
            <strong class="d-block mb-1">Seller Address</strong>
        </xpath>
    </template>

    <template id="report_purchasequotation_document_inherit_seller_address_label" inherit_id="purchase.report_purchasequotation_document">
        <xpath expr="//t[@t-set='address']/div[@t-field='o.partner_id']" position="before">
            <strong class="d-block mb-1">Seller Address</strong>
        </xpath>
    </template>
</odoo>
